# Point pkg-config to Homebrew
Sys.setenv(PKG_CONFIG_PATH=paste(c(
"/opt/homebrew/lib/pkgconfig",   # Apple Silicon
"/usr/local/lib/pkgconfig"       # Intel
), collapse=":"))
# (Optional but helpful) set include/lib hints explicitly
Sys.setenv(HDF5_DIR="/opt/homebrew/opt/hdf5")  # or "/usr/local/opt/hdf5"
Sys.setenv(CPPFLAGS="-I/opt/homebrew/opt/hdf5/include")
Sys.setenv(LDFLAGS="-L/opt/homebrew/opt/hdf5/lib")
install.packages("hdf5r", type = "source")
install.packages("remotes")
remotes::install_github("mojaveazure/seurat-disk")
remotes::install_github("mojaveazure/seurat-disk", force = TRUE)
library(Seurat)
library(SeuratDisk)
d2 <- readRDS("../dropbox-data/individualSeuratObjects/250525_egfDuodenoids_D2_DZ.rds")
## create the normalised layer of data
d2 <- NormalizeData(d2, normalization.method = "LogNormalize")
d2@assays[["RNA"]]
SaveH5Seurat(d2, filename = "../data/250525_egfDuodenoids_D2_DZ.h5Seurat")
Convert("../data/250525_egfDuodenoids_D2_DZ.h5Seurat", dest = "h5ad")
library(hdf5r)
tf <- tempfile(fileext = ".h5")
f <- H5File$new(tf, mode = "w")
f[["/x"]] <- matrix(1:9, 3)  # write a small dataset
f$close_all()
# Lean save + convert
d_lean <- DietSeurat(d2, assays="RNA", counts=TRUE, data=TRUE,
scale.data=FALSE, dimreducs=character(),
graphs=FALSE, misc=FALSE)
SaveH5Seurat(d_lean, "../data/egfDuod_lean.h5Seurat", overwrite=TRUE)
Convert("../data/egfDuod_lean.h5Seurat", dest="h5ad",
assay="RNA", overwrite=TRUE, verbose=TRUE)
